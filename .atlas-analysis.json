    "GET /pedidos - List customer orders",
    "POST /pedidos - Create customer order",
    "GET /inventario/recetas - List recipes",
    "POST /inventario/recetas/store - Create recipe",
    "POST /inventario/produccion/store - Register production",
    "GET /empleados - List employees",
    "GET /clientes - List customers",
    "GET /estadisticas - Get statistics",
    "GET /reportes/ordenes-salida - List output orders",
    "POST /api/carrito/agregar/{id} - Add to cart",
